generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  INTERVIEW_SCHEDULED
  TECHNICAL_PHASE
  FINAL_ROUND
  OFFERED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // Null for OAuth users
  name          String?
  role          Role      @default(CANDIDATE)
  onboarded     Boolean   @default(false)

  emailVerified     Boolean   @default(false)
  verifyCode        String?
  verifyCodeExpiry  DateTime?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?

  // Auth
  refreshToken  String?   @unique
  lastLogin     DateTime? @default(now())

  // Resume
  resumeUrl     String?

  // Profile
  profile       Profile?

  // Relations
  applications  Application[]
  payments      Payment[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Visitor {
  id        String   @id @default(cuid())
  name      String
  phone     String
  source    String?  @default("popup")
  createdAt DateTime @default(now())
}

model Profile {
  id              String   @id @default(cuid())

  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone           String?
  resumeUrl       String?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  bio             String?  @db.Text
  location        String?
  currentRole     String?
  avatarUrl       String? 
  experienceYears Int?

  skills          String[] @default([])

  certifications  Certification[]
  education       Education[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Certification {
  id        String   @id @default(cuid())

  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name      String
  issuer    String
  date      DateTime
  url       String?
}

model Education {
  id          String   @id @default(cuid())

  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  institution String
  degree      String
  field       String

  startDate   DateTime
  endDate     DateTime?
}

model Application {
  id          String            @id @default(cuid())

  candidateId String
  candidate   User              @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  trackId     String
  status      ApplicationStatus @default(DRAFT)

  currentStep Int               @default(1)

  // Multi-step onboarding state
  data        Json?

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Payment {
  id            String        @id @default(cuid())

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Razorpay
  orderId       String        @unique
  transactionId String?       @unique

  amount        Int
  currency      String        @default("INR")

  status        PaymentStatus @default(PENDING)

  description   String?
  receipt       String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(cuid())

  userId    String

  title     String
  message   String

  read      Boolean  @default(false)

  // PAYMENT, ONBOARDING, SYSTEM
  type      String

  createdAt DateTime @default(now())
}